{
  "name": "adoption-plan",
  "private": true,
  "version": "2.2.0",
  "description": "Adoption Planner — field-facing planning tool for designing a customer's Cribl Stream and Edge adoption — model worker groups / fleets, sources, and projected daily volume; import/export Excel workbooks (gold v0.9.1 schema). Ships as a Cribl App Platform install (.tgz) and as a single self-contained HTML file for on-prem use.",
  "author": "Michael Molina (Cribl Sr. CSE)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:standalone": "tsc -b && vite build --config vite.standalone.config.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "package": "npm run build && node scripts/package.mjs"
  },
  "dependencies": {
    "buffer": "^6.0.3",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/xlsx": "^0.0.35",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "displayName": "Adoption Planner"
}
